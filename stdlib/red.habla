// stdlib/red.habla — Utilidades de red
// Libreria estandar de Habla para operaciones de red

// Verificar si un host esta activo
fn ping(host)
  resultado = escanea host en ports [80, 443, 22]
  devuelve resultado

// Resolver un dominio
fn resolver(dominio)
  devuelve busca subdomains de dominio

// Obtener IP de un dominio (via DNS)
fn obtener_ip(dominio)
  respuesta = desde "https://dns.google/resolve?name=" + dominio + "&type=A"
  devuelve respuesta
