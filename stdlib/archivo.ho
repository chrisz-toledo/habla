// stdlib/archivo.habla — Operaciones de archivos
// Libreria estandar de Habla para manejo de archivos

// Leer un archivo de texto
fn leer_archivo(ruta)
  devuelve lee ruta

// Guardar texto en un archivo
fn guardar_archivo(contenido, ruta)
  guarda contenido en ruta

// Leer lineas de un archivo como lista
fn leer_lineas(ruta)
  contenido = lee ruta
  devuelve contenido
