muestra "=== INICIANDO PRUEBA 2: PIPES ==="

objetivos = ["192.168.1.1", "10.0.0.5", "scanme.nmap.org"]

muestra "[*] Imprimiendo matriz original usando pipe:"
objetivos -> muestra

