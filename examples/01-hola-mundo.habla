// 01-hola-mundo.habla — Primer programa en Habla
// Ejecutar: habla run 01-hola-mundo.habla

muestra "Hola mundo desde Habla!"

nombre = "Christian"
muestra "Bienvenido, " + nombre

// Variables y tipos implicitos
edad = 25
activo = cierto
pi = 3.14

muestra "Edad: " + edad
muestra "Activo: " + activo

// Condicional
si edad >= 18
  muestra "Mayor de edad"
sino
  muestra "Menor de edad"
